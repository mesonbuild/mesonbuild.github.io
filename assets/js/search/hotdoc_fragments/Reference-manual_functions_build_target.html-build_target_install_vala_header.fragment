fragment_downloaded_cb({"url":"Reference-manual_functions_build_target.html#build_target_install_vala_header","fragment":"If set to a string value, the vala generated header will be installed to\nthat path, if set to true, the default include path will be used, if\nfalse the header will not be installed.\nThe default value is false.\n(since 1.11.0)\n"});