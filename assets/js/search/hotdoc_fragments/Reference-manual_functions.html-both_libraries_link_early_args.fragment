fragment_downloaded_cb({"url":"Reference-manual_functions.html#both_libraries_link_early_args","fragment":"Flags to use during linking. These are just like link_args,\nexcept that they are inserted into the linker command line\nbefore any object files or libraries. You can use UNIX-style\nflags here for all platforms. This is only supported when using\nthe Ninja backend.\n"});