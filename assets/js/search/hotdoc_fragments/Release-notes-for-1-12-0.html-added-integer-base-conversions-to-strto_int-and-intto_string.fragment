fragment_downloaded_cb({"url":"Release-notes-for-1-12-0.html#added-integer-base-conversions-to-strto_int-and-intto_string","fragment":"Added integer base conversions to str.to_int() and int.to_string()\n\nMeson strings can now be converted from hexadecimal, octal, and binary\ninteger literals with str.to_int(). Integers can also be formatted back to\nstrings in those bases with int.to_string(format:).\n"});