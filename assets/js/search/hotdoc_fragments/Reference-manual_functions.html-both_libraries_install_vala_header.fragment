fragment_downloaded_cb({"url":"Reference-manual_functions.html#both_libraries_install_vala_header","fragment":"If set to a string value, the vala generated header will be installed to\nthat path, if set to true, the default include path will be used, if\nfalse the header will not be installed.\nIf it is unset then the value of install_dir will be used.\n(since 1.11.0)\n"});