fragment_downloaded_cb({"url":"Reference-manual_functions.html#shared_library_install_vala_vapi","fragment":"If set to a string value, the vala generated vapi library will be\ninstalled to that path, if set to true, the default vapi path will be\nused, if false the vapi library will not be installed.\nIf it is unset then the value of install_dir will be used.\n(since 1.11.0)\n"});