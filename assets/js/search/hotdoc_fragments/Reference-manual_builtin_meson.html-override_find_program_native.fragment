fragment_downloaded_cb({"url":"Reference-manual_builtin_meson.html#override_find_program_native","fragment":"If set to true, the override is for the build machine, and will be returned\nby find_program(..., native : true), otherwise for the host machine. This\nis an important distinction when cross compiling.\n(since 1.12.0)\ndefault =\n  false\n"});